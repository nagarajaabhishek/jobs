# Copy to .env and fill in. Do not commit .env.

# --- OpenRouter (when evaluation.provider: openrouter in config/pipeline.yaml) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# Optional: override API root (default https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional headers (recommended by OpenRouter for rankings)
# OPENROUTER_HTTP_REFERER=https://github.com/your/repo
# OPENROUTER_APP_NAME=Job Automation

# --- Gemini (when evaluation.provider: gemini) ---
# GEMINI_API_KEY=your_gemini_api_key
# Paid / higher RPM: no delay between Gemini calls (default is 0.5s for free-tier RPM).
# GEMINI_REQUEST_DELAY_SEC=0
# Larger batch eval JSON (default 8192 in code); raise if batch_eval_size is high.
# GEMINI_MAX_OUTPUT_TOKENS=16384

# --- OpenAI / ChatGPT API (when provider: openai, or Gemini fallback with openai_then_gemma / openai) ---
# Default chain for gemini provider in pipeline.yaml: openai_then_gemma. Override:
# EVAL_FALLBACK_PROVIDER=openai_then_gemma
# OPENAI_API_KEY=sk-...
# Optional: model (default gpt-4o-mini; override config evaluation.openai_model)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_COMPLETION_TOKENS=8192

# Optional: hosted Gemma model id when using fallback_provider gemma / gemma_then_openai (overrides pipeline.yaml gemma_model).
# GEMINI_GEMMA_MODEL=gemma-4-31b-it

# --- Optional: profile path for job-fit evaluation ---
# Directory containing master_context.yaml (default: hardcoded path in evaluate_jobs.py)
# PROFILE_DIR=/path/to/Resume_Agent/.agent/data/YourName/
# Or full path to the YAML file:
# MASTER_PROFILE_PATH=/path/to/master_context.yaml
# Optional: compiled context path (defaults to data/dense_master_matrix.json in repo root)
# DENSE_MATRIX_PATH=/path/to/dense_master_matrix.json

# --- Optional: pipeline config ---
# Path to pipeline.yaml (default: config/pipeline.yaml)
# PIPELINE_CONFIG=config/pipeline.yaml

# --- Google Sheet (existing workbook) ---
# Paste full URL or raw spreadsheet ID so the pipeline opens this file (no Drive "create").
# Same as config/pipeline.yaml -> sheet.spreadsheet_id. Env wins if both are set.
# GOOGLE_SHEET_ID=https://docs.google.com/spreadsheets/d/YOUR_ID_HERE/edit
# Optional: force daily tab (YYYY-MM-DD). Overrides sheet.worksheet_tab_date_mode in pipeline.yaml.
# SHEET_TAB_DATE=2026-04-09
# Tab date mode without editing YAML: yesterday | today | fixed (use with SHEET_TAB_DATE_FIXED=YYYY-MM-DD).
# SHEET_TAB_DATE_MODE=fixed
# SHEET_TAB_DATE_FIXED=2026-04-09

# --- Google Sheets API pacing / retries (reduces 429 read/write bursts) ---
# Minimum seconds between Sheets API calls (0 = off).
# SHEETS_MIN_REQUEST_INTERVAL_SEC=0.25
# Max retries per operation (default 6).
# SHEETS_RETRY_MAX=8
# Base sleep for non-quota retries in seconds (default 1.5).
# SHEETS_RETRY_BASE_SLEEP=2

# When append fails, jobs are written as JSON here; replay with:
#   python scripts/tools/replay_sheet_fallback_queue.py
# SHEET_APPEND_FALLBACK_DIR=/path/to/sheet_append_fallback
# If 0/false/no, skip writing JSON files on append failure (SQLite outbox may still record).
# SHEET_APPEND_FALLBACK_JSON=1

# SQLite outbox when Sheets append/update fails (see config/pipeline.yaml local_store).
# PIPELINE_OUTBOX_DB=/absolute/path/pipeline_outbox.db
# LOCAL_STORE_ENABLED=1

# --- Pipeline phase gates (overnight / flaky Sheets) ---
# If phase-gate reads fail with quota/429 after retries, skip target + clean-sheet gates instead of failing.
# PIPELINE_SKIP_TARGET_GATE_ON_SHEETS_ERROR=1

# --- Optional HTTP API (apps/api) ---
# When set, /v1/* routes require header X-API-Key matching this value.
# JOB_AUTOMATION_API_KEY=your-long-random-secret
